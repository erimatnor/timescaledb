 _timescaledb_internal._hyper_28_84_chunk
 _timescaledb_internal._hyper_28_85_chunk

-- Test chunk exclusion with different predicates
EXPLAIN (COSTS OFF) SELECT * FROM chunk_excl_test WHERE time >= '2025-01-05' AND time < '2025-01-07';
--- QUERY PLAN ---
 Append
   ->  Index Scan using _hyper_28_80_chunk_chunk_excl_test_time_idx on _hyper_28_80_chunk
         Index Cond: (("time" >= 'Sun Jan 05 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Tue Jan 07 00:00:00 2025 UTC'::timestamp with time zone))
   ->  Index Scan using _hyper_28_81_chunk_chunk_excl_test_time_idx on _hyper_28_81_chunk
         Index Cond: (("time" >= 'Sun Jan 05 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Tue Jan 07 00:00:00 2025 UTC'::timestamp with time zone))

-- Verify data in excluded range
SELECT count(*) FROM chunk_excl_test WHERE time >= '2025-01-05' AND time < '2025-01-07';
