 constraint_43 | c    | {time}  | -     | (("time" >= 'Sun Mar 09 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Mon Mar 10 00:00:00 2025 UTC'::timestamp with time zone)) | f          | f        | t
 constraint_44 | c    | {time}  | -     | (("time" >= 'Mon Mar 10 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Tue Mar 11 00:00:00 2025 UTC'::timestamp with time zone)) | f          | f        | t
 constraint_45 | c    | {time}  | -     | (("time" >= 'Sun Nov 02 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Mon Nov 03 00:00:00 2025 UTC'::timestamp with time zone)) | f          | f        | t
 constraint_46 | c    | {time}  | -     | (("time" >= 'Mon Nov 03 00:00:00 2025 UTC'::timestamp with time zone) AND ("time" < 'Tue Nov 04 00:00:00 2025 UTC'::timestamp with time zone)) | f          | f        | t

