---------------+------+---------+-------+------------------------------------------------------------------------------------------------------------------------------------------------+------------+----------+-----------
 constraint_15 | c    | {time}  | -     | (("time" >= 'Sun Dec 01 00:00:00 2024 PST'::timestamp with time zone) AND ("time" < 'Wed Jan 01 00:00:00 2025 PST'::timestamp with time zone)) | f          | f        | t
 constraint_16 | c    | {time}  | -     | (("time" >= 'Wed Jan 01 00:00:00 2025 PST'::timestamp with time zone) AND ("time" < 'Sat Feb 01 00:00:00 2025 PST'::timestamp with time zone)) | f          | f        | t
 constraint_17 | c    | {time}  | -     | (("time" >= 'Sat Feb 01 00:00:00 2025 PST'::timestamp with time zone) AND ("time" < 'Sat Mar 01 00:00:00 2025 PST'::timestamp with time zone)) | f          | f        | t

DROP TABLE tz_monthly;
