-- SECTION 3: TIMESTAMP (WITHOUT TIME ZONE) PARTITIONING
---------------------------------------------------------------
CREATE TABLE ts_daily(
    time timestamp NOT NULL,
    device_id int,
    value float
);
SELECT create_hypertable('ts_daily', 'time', chunk_time_interval => interval '1 day');
WARNING:  column type "timestamp without time zone" used for "time" does not follow best practices
   create_hypertable   
-----------------------
 (8,public,ts_daily,t)

-- Insert data spanning multiple days
INSERT INTO ts_daily VALUES
    ('2025-01-01 00:00:00', 1, 1.0),
    ('2025-01-01 23:59:59.999999', 1, 1.5),
    ('2025-01-02 00:00:00', 2, 2.0),
    ('2025-01-02 12:00:00', 2, 2.5),
    ('2025-01-03 00:00:00', 3, 3.0);
SELECT * FROM show_chunks('ts_daily');
               show_chunks               
-----------------------------------------
 _timescaledb_internal._hyper_8_24_chunk
 _timescaledb_internal._hyper_8_25_chunk
 _timescaledb_internal._hyper_8_26_chunk

SELECT (test.show_constraints(ch)).* FROM show_chunks('ts_daily') ch;
  Constraint   | Type | Columns | Index |                                                                     Expr                                                                     | Deferrable | Deferred | Validated 
---------------+------+---------+-------+----------------------------------------------------------------------------------------------------------------------------------------------+------------+----------+-----------
 constraint_24 | c    | {time}  | -     | (("time" >= 'Wed Jan 01 00:00:00 2025'::timestamp without time zone) AND ("time" < 'Thu Jan 02 00:00:00 2025'::timestamp without time zone)) | f          | f        | t
 constraint_25 | c    | {time}  | -     | (("time" >= 'Thu Jan 02 00:00:00 2025'::timestamp without time zone) AND ("time" < 'Fri Jan 03 00:00:00 2025'::timestamp without time zone)) | f          | f        | t
 constraint_26 | c    | {time}  | -     | (("time" >= 'Fri Jan 03 00:00:00 2025'::timestamp without time zone) AND ("time" < 'Sat Jan 04 00:00:00 2025'::timestamp without time zone)) | f          | f        | t

-- Test timestamp boundary values
BEGIN;
INSERT INTO ts_daily VALUES ('4714-11-24 00:00:00 BC', -1, -1.0);  -- Min timestamp
SELECT (test.show_constraints(ch)).* FROM show_chunks('ts_daily') ch
ORDER BY 1 DESC LIMIT 1;
  Constraint   | Type | Columns | Index |                                                                        Expr                                                                        | Deferrable | Deferred | Validated 
---------------+------+---------+-------+----------------------------------------------------------------------------------------------------------------------------------------------------+------------+----------+-----------
 constraint_27 | c    | {time}  | -     | (("time" >= 'Mon Nov 24 00:00:00 4714 BC'::timestamp without time zone) AND ("time" < 'Tue Nov 25 00:00:00 4714 BC'::timestamp without time zone)) | f          | f        | t

ROLLBACK;
DROP TABLE ts_daily;
