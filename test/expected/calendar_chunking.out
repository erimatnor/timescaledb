WHERE time >= '2025-03-08' AND time < '2025-03-11'
ORDER BY time;
             time             | device_id | value 
------------------------------+-----------+-------
 Sat Mar 08 23:00:00 2025 EST |         1 |     1
 Sun Mar 09 01:00:00 2025 EST |         2 |     2
 Sun Mar 09 03:00:00 2025 EDT |         3 |     3
 Sun Mar 09 12:00:00 2025 EDT |         4 |     4
 Mon Mar 10 00:00:00 2025 EDT |         5 |     5

SET timezone = 'UTC';
SELECT time, device_id, value FROM tz_dst_test
WHERE time >= '2025-03-08' AND time < '2025-03-11'
ORDER BY time;
             time             | device_id | value 
------------------------------+-----------+-------
 Sun Mar 09 04:00:00 2025 UTC |         1 |     1
 Sun Mar 09 06:00:00 2025 UTC |         2 |     2
 Sun Mar 09 07:00:00 2025 UTC |         3 |     3
 Sun Mar 09 16:00:00 2025 UTC |         4 |     4
 Mon Mar 10 04:00:00 2025 UTC |         5 |     5

DROP TABLE tz_dst_test;
